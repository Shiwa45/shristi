# Production environment variables
# Copy this file to .env and fill in the values

# Django settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=13.61.189.208,localhost,127.0.0.1

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=shristi_db
DB_USER=shristi_user
DB_PASSWORD=your-secure-password-here
DB_HOST=localhost
DB_PORT=5432

# Or use SQLite for simplicity
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=/home/ubuntu/shristi/db.sqlite3

# CORS
CORS_ALLOWED_ORIGINS=http://13.61.189.208,http://localhost:3000

# Static files
STATIC_ROOT=/home/ubuntu/shristi/staticfiles
MEDIA_ROOT=/home/ubuntu/shristi/media
