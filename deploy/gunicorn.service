[Unit]
Description=Gunicorn daemon for Shristi Printing
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/shristi
Environment="PATH=/home/ubuntu/shristi/venv/bin"
ExecStart=/home/ubuntu/shristi/venv/bin/gunicorn \
          --config /home/ubuntu/shristi/deploy/gunicorn_config.py \
          shirsti_printing.wsgi:application

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
